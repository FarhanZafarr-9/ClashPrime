{
  "expo": {
    "name": "ClashPrime",
    "slug": "ClashPrime",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "clashprime",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clashprime.app"
    },
    "android": {
      "adaptiveIcon": { "foregroundImage": "./images/icon.png", "backgroundColor": "#ffffff"
      },
      "package": "com.clashprime.app",
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "favicon": "./images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/05158f35-ef70-4899-a1ed-916838720598",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05158f35-ef70-4899-a1ed-916838720598"
      }
    },
    "owner": "parzival_89"
  }
}

